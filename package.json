{
  "name": "openclaw-better-hooks",
  "version": "1.0.0",
  "description": "System-wide log event bus implemented as an OpenClaw Plugin.",
  "type": "module",
  "license": "MIT",
  "author": "Anthony",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "openclaw-hooks": "./src/cli.js"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "defaultChoice": "npm",
      "localPath": ".",
      "npmSpec": "openclaw-better-hooks"
    }
  },
  "dependencies": {
    "commander": "^14.0.3",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
